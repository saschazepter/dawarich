           subtitle: (@share ? "#{@share.settings['start_date']} → #{@share.settings['end_date']} is shared via a public link." : nil),
           close_path: map_v2_path,
           paths: {
             create:            share_links_timeline_path,
             revoke:            revoke_share_links_timeline_path,
             regenerate:        regenerate_share_links_timeline_path,
             regenerate_phrase: regenerate_phrase_share_links_timeline_path,
             destroy:           share_links_timeline_path
           },
           create_form_partial: 'shared_links/modal_timeline_create_form' %>
