<%# Locals: link, resource (always nil for timeline) %>
<%
  start_date = Date.parse(link.settings['start_date'].to_s)
  end_date   = Date.parse(link.settings['end_date'].to_s)
%>
<section class="container mx-auto px-4 py-6">
  <h1 class="text-3xl font-bold mb-2">Timeline</h1>
  <p class="text-base-content/70">
    <%= l(start_date, format: :long) %> –
    <%= l(end_date, format: :long) %>
    · <%= (end_date - start_date).to_i + 1 %> days
  </p>

  <div id="shared-trip-map"
       data-controller="shared-trip-map"
       data-shared-trip-map-link-id-value="<%= link.id %>"
       data-shared-trip-map-show-photos-value="<%= link.settings['show_photos'] %>"
       data-shared-trip-map-show-places-value="<%= link.settings['show_places'] %>"
       style="height: 60vh; min-height: 400px;"
       class="rounded-lg overflow-hidden bg-base-200 my-6"></div>
</section>
