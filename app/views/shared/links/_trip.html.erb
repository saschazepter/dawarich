<% ctx     = SharedLinkContext.new(link) %>
<% unit    = link.user.safe_settings.distance_unit %>
<% tz      = link.user.timezone_iana %>
<% has_map = ctx.show_route? %>
<%
  wrapper_data = if has_map
    {
      controller: 'shared-trip-map',
      'shared-trip-map-link-id-value': link.id,
      'shared-trip-map-show-photos-value': ctx.show_photos?,
      'shared-trip-map-by-day-value': true,
      'shared-trip-map-timezone-value': tz
    }
  else
    {}
  end
%>

<%= tag.div class: 'container mx-auto px-4 my-5', data: wrapper_data do %>
  <%# Side-by-side layout mirroring the internal trip page: map card left, scrollable content right %>
  <div class="flex flex-col lg:flex-row gap-6 <%= 'lg:h-[calc(100dvh-9.75rem)]' if has_map %>">
    <% if has_map %>
      <div class="w-full lg:w-3/5 h-[50vh] lg:h-full shrink-0">
        <div data-shared-trip-map-target="map"
             class="w-full h-full rounded-lg overflow-hidden bg-base-200 relative">
          <%= render "shared/replay_panel", stimulus: "shared-trip-map", show_day_nav: true %>
        </div>
      </div>
    <% end %>

    <div class="w-full <%= has_map ? 'lg:w-2/5 lg:h-full lg:overflow-y-auto' : 'max-w-2xl mx-auto' %>">
      <%# Trip header %>
      <div class="mb-6">
        <div class="flex items-start justify-between gap-3 mb-1">
          <h1 class="text-3xl font-bold leading-tight"><%= resource.name %></h1>
          <span class="badge badge-success badge-sm shrink-0 gap-1" aria-label="Publicly shared">
            <%= icon 'map-pin', class: 'w-3 h-3' %> Public
          </span>
        </div>
        <p class="text-md text-base-content/60 mb-4">
          <%= human_date(resource.started_at) %> &ndash; <%= human_date(resource.ended_at) %>
        </p>

        <% if ctx.show_stats? %>
          <%= render "trips/countries", trip: resource, current_user: link.user, distance_unit: unit %>
        <% end %>
      </div>

      <%# Trip description (above the day-by-day breakdown) %>
      <% if ctx.show_description? && resource.description.body.present? %>
        <div class="mb-6">
          <h3 class="text-lg font-semibold mb-2">Trip Notes</h3>
          <div class="prose max-w-none"><%= resource.description.body %></div>
        </div>
      <% end %>

      <% if has_map %>
        <div class="flex items-center gap-2 mb-4">
          <button type="button"
                  class="btn btn-sm btn-outline gap-1"
                  data-shared-trip-map-target="replayToggleBtn"
                  data-action="click->shared-trip-map#toggleReplay">
            <%= icon 'play', class: 'w-4 h-4' %>
            <span>Replay</span>
          </button>
        </div>
      <% end %>

      <%# Accordion days — hovering a row highlights the day on the map, clicking pins it %>
      <% if ctx.show_days? %>
        <% days = SharedLinks::TripDays.new(resource, timezone: tz, unit: unit).call %>
        <% notes = ctx.show_day_notes? ? resource.notes.index_by(&:date) : {} %>
        <% if days.any? %>
          <%
            row_actions = 'mouseenter->shared-trip-map#hoverDay ' \
                          'mouseleave->shared-trip-map#leaveDay ' \
                          'click->shared-trip-map#toggleDay'
            interactive = has_map ? ' cursor-pointer transition-colors hover:bg-base-300' : ''
          %>
          <div class="space-y-1 mb-6 px-1">
            <% days.each do |day| %>
              <% day_key = day[:date].strftime('%Y-%m-%d') %>
              <% note = notes[day[:date]] %>
              <% row_data = has_map ? { day_key: day_key, action: row_actions, 'shared-trip-map-day-key-param': day_key } : {} %>
              <% if ctx.show_day_notes? && note&.body.present? %>
                <%= tag.details class: "collapse collapse-arrow bg-base-200 rounded-lg#{interactive}", data: row_data do %>
                  <summary class="collapse-title flex items-center gap-2 text-sm font-medium min-h-0 cursor-pointer">
                    <%= render "shared/links/trip_day_header", day: day, day_key: day_key %>
                  </summary>
                  <div class="collapse-content">
                    <p class="whitespace-pre-wrap text-sm text-base-content/80"><%= note.body %></p>
                  </div>
                <% end %>
              <% else %>
                <%= tag.div class: "bg-base-200 rounded-lg px-4 py-3 flex items-center gap-2 text-sm font-medium#{interactive}", data: row_data do %>
                  <%= render "shared/links/trip_day_header", day: day, day_key: day_key %>
                <% end %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
