<dialog class="ach-modal"
        data-card-modal-target="dialog"
        data-action="close->card-modal#restore click->card-modal#backdrop"
        aria-label="Achievement detail">
  <button type="button" class="ach-modal-close" data-action="click->card-modal#close" aria-label="Close">&times;</button>

  <div class="ach-modal-stage" data-card-modal-target="stage"></div>

  <div class="ach-modal-tools" data-card-modal-target="tools" hidden>
    <button type="button" class="ach-btn" data-action="click->card-modal#share">Share</button>
    <button type="button" class="ach-btn" data-action="click->card-modal#embed">Embed</button>
  </div>

  <div class="ach-modal-panel" data-card-modal-target="panel" hidden>
    <div class="ach-modal-panel-label" data-card-modal-target="panelLabel"></div>
    <div class="ach-modal-copyrow">
      <input type="text" readonly class="ach-modal-output" data-card-modal-target="output">
      <button type="button" class="ach-btn" data-action="click->card-modal#copy" data-card-modal-target="copyBtn">Copy</button>
    </div>
    <button type="button" class="ach-modal-unshare" data-action="click->card-modal#unshare" data-card-modal-target="unshareBtn" hidden>
      Stop sharing
    </button>
  </div>

  <div class="ach-modal-error" data-card-modal-target="error" role="alert" hidden></div>
</dialog>
