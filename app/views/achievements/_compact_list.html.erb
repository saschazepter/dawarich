<ol class="ach-list">
  <% rows.each do |row| %>
    <li class="ach-row <%= 'ach-row--earned' if row[:earned_at] %>">
      <span class="ach-row-mark" aria-hidden="true"></span>
      <span class="ach-row-name">
        <% if row[:key] %>
          <%= link_to row[:name], achievement_path(row[:key]) %>
        <% else %>
          <%= row[:name] %>
        <% end %>
      </span>
      <span class="ach-row-code"><%= row[:code] %></span>
      <span class="ach-row-date">
        <%= row[:earned_at] ? Date.parse(row[:earned_at]).strftime('%-d %b %Y') : '—' %>
      </span>
    </li>
  <% end %>
</ol>

<div class="ach-pagination">
  <%= paginate rows %>
</div>
