<%# locals: (name:, rarity:, map_lat:, map_lon:, map_zoom:, marker_lat: nil, marker_lon: nil, description: nil, flavor: nil, place: nil, size: :md, percent: 0, completed: false, locked: false, earned_label: nil, celebrate: false, reveal_delay: 0.1) %>
<div class="ach-card-wrap <%= 'ach-card-wrap--celebrate' if celebrate %>" style="--reveal-delay: <%= reveal_delay %>s;"
     data-controller="achievement-card"
     data-achievement-card-locked-value="<%= locked %>"
     data-action="mousemove->achievement-card#move mouseleave->achievement-card#leave">
  <% state_class = locked ? 'ach-card--locked' : (completed ? '' : 'ach-card--partial') %>
  <div class="ach-card <%= 'ach-card--sm' if size == :sm %> ach-card--<%= rarity.downcase %> <%= state_class %>">
    <div class="ach-frame">
      <div class="ach-art" role="img" aria-label="<%= place || name %>"
           data-controller="achievement-map"
           data-achievement-map-lat-value="<%= map_lat %>"
           data-achievement-map-lng-value="<%= map_lon %>"
           data-achievement-map-zoom-value="<%= map_zoom %>"
           <% if marker_lat %>
             data-achievement-map-marker-lat-value="<%= marker_lat %>"
             data-achievement-map-marker-lng-value="<%= marker_lon %>"
           <% end %>>
        <div class="ach-art-canvas" data-achievement-map-target="host"></div>
        <div class="ach-art-shade"></div>
        <% if !locked && !completed %>
          <div class="ach-art-fog" style="opacity: <%= ((1 - (percent / 100.0)) * 0.9).round(2) %>;"></div>
        <% end %>
        <% if locked %>
          <div class="ach-art-lock"><%= icon 'lock' %></div>
        <% else %>
          <div class="ach-pin" data-achievement-map-target="pin">
            <div class="ach-pin-head"></div>
            <div class="ach-pin-shadow"></div>
          </div>
        <% end %>
      </div>
      <div class="ach-plate">
        <div class="ach-plate-name"><%= name %></div>
      </div>
      <% if description || flavor %>
        <div class="ach-body">
          <p class="ach-desc"><%= description %></p>
          <div class="ach-flavor"><%= flavor %></div>
        </div>
      <% end %>
      <div class="ach-rarity-row">
        <div class="ach-rarity"><%= rarity %></div>
      </div>
      <% if earned_label %>
        <div class="ach-earned"><%= earned_label %></div>
      <% end %>
    </div>
    <div class="ach-badge <%= 'ach-badge--progress' unless locked %>">
      <% if locked %>
        <%= icon 'lock' %>
      <% else %>
        <div class="ach-badge-ring" style="--progress-deg: <%= (percent * 3.6).round %>deg;"></div>
        <div class="ach-badge-text"><%= completed ? '✓' : "#{percent}%" %></div>
      <% end %>
    </div>
    <div class="ach-holo"></div>
    <% if rarity == 'Legendary' && completed %>
      <div class="ach-shimmer"></div>
    <% end %>
    <% if celebrate || (rarity == 'Legendary' && completed) %>
      <div class="ach-sparks">
        <% 6.times do %><div class="ach-spark"></div><% end %>
      </div>
    <% end %>
    <div class="ach-back">
      <div class="ach-back-medallion">D</div>
    </div>
  </div>
</div>
