
<div class="container mx-auto px-4 py-8">
  <div class="ach-page">
    <div class="ach-layout">
      <%= render 'sidebar', continents: @sets, tiers: @tiers, summary: @summary %>

      <div class="ach-main">
        <div class="ach-header">
          <div class="ach-kicker">Dawarich</div>
          <h1 class="ach-title">Achievements</h1>
          <p class="ach-hint">
            <%= @summary.earned_countries %> of <%= @summary.total_countries %> countries ·
            <%= @summary.earned_subdivisions %> of <%= @summary.total_subdivisions %> regions
          </p>
        </div>

        <div class="ach-divider"><span>Continents</span></div>

        <div class="ach-grid">
          <% @sets.each_with_index do |set, index| %>
            <%= link_to achievement_path(set.definition.key), class: 'ach-card-link' do %>
              <%= render 'card', reveal_delay: 0.1 + (0.15 * [index, 10].min),
                                 celebrate: set.celebrate?,
                                 **set.card_attributes %>
            <% end %>
          <% end %>
          <% @orphans.each_with_index do |set, index| %>
            <%= render 'card', reveal_delay: 0.1 + (0.15 * [@sets.size + index, 10].min),
                               celebrate: set.celebrate?,
                               **set.card_attributes %>
          <% end %>
        </div>

        <div class="ach-divider"><span>World</span></div>

        <div class="ach-grid">
          <% @tiers.each_with_index do |set, index| %>
            <%= link_to achievement_path(set.definition.key), class: 'ach-card-link' do %>
              <%= render 'card', reveal_delay: 0.1 + (0.15 * [index, 10].min),
                                 celebrate: set.celebrate?,
                                 **set.card_attributes %>
            <% end %>
          <% end %>
        </div>

        <p class="ach-footnote">
          Region detection is based on approximate boundaries.
          Boundaries: Natural Earth (public domain) and
          <%= link_to 'geoBoundaries', 'https://www.geoboundaries.org', target: '_blank', rel: 'noopener' %> (CC BY 4.0).
          Map art: Protomaps © OpenStreetMap contributors
        </p>
      </div>
    </div>
  </div>
</div>
