<% interactive = local_assigns.fetch(:interactive, true) %>
<div class="ach-slot">
  <%= render 'achievements/card',
             reveal_delay: local_assigns.fetch(:reveal_delay, 0.1),
             **set.card_attributes %>

  <details class="ach-details">
    <summary><%= set.display_count %>/<%= set.target %> regions</summary>
    <ul class="ach-regions">
      <% set.regions.each do |region| %>
        <li class="<%= 'ach-region--pending' unless region[:earned_at] %>">
          <span><%= region[:name] %></span>
          <span><%= region[:earned_at] ? Date.parse(region[:earned_at]).strftime('%-d %b %Y') : '—' %></span>
        </li>
      <% end %>
    </ul>
  </details>

  <% if interactive %>
    <div class="ach-actions">
      <%= button_to set.sharing_enabled? ? 'Disable sharing' : 'Share',
                    toggle_sharing_achievement_path(set.definition.key),
                    method: :patch, class: 'ach-btn' %>
      <% if set.sharing_enabled? %>
        <%= link_to 'Public link', shared_achievement_path(set.sharing_uuid), class: 'ach-btn' %>
      <% end %>
    </div>
  <% end %>
</div>
