<% content_for :title, 'Videos' %>

<div class="w-full my-5" data-controller="videos-subscription">
  <%= render 'shared/page_header', title: 'Videos' %>

  <div id="videos" class="min-w-full">
    <% if @videos.any? %>
      <div class="flex justify-center mb-4">
        <%= paginate @videos %>
      </div>
    <% end %>

    <div class="border border-base-300 rounded-xl">
      <table class="table w-full">
        <thead class="bg-base-200">
          <tr>
            <th class="px-4 py-3 text-xs uppercase tracking-wider text-base-content/50 w-[45%] rounded-tl-xl"><%= sortable_column 'Period', :start_at, :videos_path %></th>
            <th class="px-4 py-3 text-xs uppercase tracking-wider text-base-content/50 w-[15%]"><%= sortable_column 'Status', :status, :videos_path %></th>
            <th class="px-4 py-3 text-xs uppercase tracking-wider text-base-content/50 w-[20%]"><%= sortable_column 'Created', :created_at, :videos_path %></th>
            <th class="px-4 py-3 text-xs uppercase tracking-wider text-base-content/50 text-right w-[20%] rounded-tr-xl">Actions</th>
          </tr>
        </thead>
        <tbody data-videos-subscription-target="tbody">
          <% if @videos.any? %>
            <%= render partial: 'video', collection: @videos, as: :video %>
          <% else %>
            <tr data-videos-empty>
              <td colspan="4" class="text-center py-16 text-base-content/50">
                <p class="text-lg font-medium mb-2">No videos yet</p>
                <p class="text-sm">Start a route replay video from a track or day in your timeline.</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @videos.any? %>
      <div class="flex justify-center mt-4">
        <%= paginate @videos %>
      </div>
    <% end %>
  </div>
</div>
