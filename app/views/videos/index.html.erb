<div class="max-w-4xl mx-auto p-4"
     data-controller="videos-subscription">
  <header class="flex items-center justify-between mb-4">
    <h1 class="text-2xl font-bold flex items-center gap-2">
      <%= icon 'video', class: 'w-6 h-6' %>
      Videos
    </h1>
  </header>

  <% if @videos.any? %>
    <div class="overflow-x-auto bg-base-100 rounded-box border border-base-300">
      <table class="table table-zebra">
        <thead>
          <tr>
            <th>Name</th>
            <th>Status</th>
            <th>Created</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody data-videos-subscription-target="tbody">
          <%= render partial: 'video', collection: @videos, as: :video %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert">
      <span>No videos yet — start one from a track or day in your timeline.</span>
    </div>
  <% end %>
</div>
