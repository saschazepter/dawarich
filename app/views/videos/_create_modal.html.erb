<dialog data-video-form-target="dialog" class="modal">
  <div class="modal-box max-w-sm">
    <h3 class="font-bold text-lg mb-4" data-video-form-target="title">Generate replay video</h3>

    <%= form_with url: videos_path, method: :post,
                  data: { turbo: true, action: 'turbo:submit-end->video-form#closeOnSuccess' },
                  html: { autocomplete: 'off' } do |f| %>
      <input type="hidden" name="track_id" data-video-form-target="trackId" />
      <input type="hidden" name="date" data-video-form-target="date" />

      <label class="form-control w-full mb-4">
        <div class="label">
          <span class="label-text">Video name</span>
          <span class="label-text-alt text-base-content/50">Optional</span>
        </div>
        <%= f.text_field :name,
              placeholder: 'e.g. Morning run',
              maxlength: 200,
              class: 'input input-bordered input-sm w-full',
              data: { video_form_target: 'name' } %>
        <div class="label">
          <span class="label-text-alt text-base-content/50">
            Shown on the videos page and in the video's title overlay.
          </span>
        </div>
      </label>

      <div class="modal-action">
        <button type="button" class="btn btn-ghost btn-sm" data-action="click->video-form#close">Cancel</button>
        <%= f.submit 'Generate', class: 'btn btn-primary btn-sm' %>
      </div>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

