<%# Generic share-link modal chrome.
    Used by Trip + Timeline (+ future Live).
    Locals:
      resource           — the object being shared (Trip / nil for timeline)
      share              — the active SharedLink, or nil
      title              — string shown as modal heading when share is nil
      close_path         — where the X / Cancel / backdrop sends the user
      paths              — Hash with keys: create, revoke, regenerate, regenerate_phrase, destroy
      create_form_partial — partial path for the create form (rendered when share is nil)
%>
<turbo-frame id="trip-share-modal">
  <div class="modal modal-open">
    <div class="modal-box max-w-xl">
      <%= link_to close_path,
                  class: "btn btn-sm btn-circle btn-ghost absolute right-3 top-3",
                  data: { turbo_frame: "_top" },
                  aria: { label: "Close" } do %>
        ✕
      <% end %>

      <% if share %>
        <%= render 'shared_links/modal_active', share: share, paths: paths %>
      <% else %>
        <h3 class="font-bold text-lg mb-1"><%= title %></h3>
        <p class="text-sm text-base-content/70 mb-5">Anyone with the link will be able to view this.</p>
        <%= render create_form_partial, resource: resource, paths: paths, close_path: close_path %>
      <% end %>
    </div>
    <%= link_to '', close_path, class: "modal-backdrop", data: { turbo_frame: "_top" }, aria: { label: "Close" } %>
  </div>
</turbo-frame>
